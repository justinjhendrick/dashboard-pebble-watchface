{
  "name": "Tempilation",
  "author": "justinjhendrick, SocketMix",
  "version": "1.5.0",
  "keywords": [
    "pebble-watchface",
    "digital",
    "galaxy",
    "dashboard",
    "configurable",
    "temperature",
    "battery",
    "steps"
  ],
  "private": false,
  "dependencies": {
    "@rebble/clay": "^1.0.8"
  },
  "pebble": {
    "displayName": "Tempilation",
    "uuid": "658a0530-fdbb-4573-a047-303111dee408",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "color_background",
      "color_time_text",
      "color_corner_title",
      "color_corner_value",
      "color_separator",
      "include_seconds",
      "month_first",
      "temperature_in_celsius",
      "temperature_tenths",
      "leading_zero_hour_in_12h",
      "am_pm_in_12h",
      "leading_zero_in_date",
      "weather_now_temp_deci_c"
    ],
    "resources": {
      "media": [
        {"name": "ROBOTO_68", "file": "fonts/Roboto-Regular.ttf", "characterRegex": "[ 0-9:\\.]", "type": "font"},
        {"name": "ROBOTO_50", "file": "fonts/Roboto-Regular.ttf", "characterRegex": "[ 0-9:\\.]", "type": "font"},
        {"name": "ROBOTO_34", "file": "fonts/Roboto-Regular.ttf", "characterRegex": "[ a-zA-Z0-9:%\\.\\-°/]", "type": "font"},
        {"name": "ROBOTO_22", "file": "fonts/Roboto-Regular.ttf", "characterRegex": "[ a-zA-Z0-9:%\\.\\-°/]", "type": "font"}
      ]
    }
  }
}
